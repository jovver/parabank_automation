{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$f\" =~ \\.tsx?$ ]] || exit 0; npx tsc --noEmit",
            "statusMessage": "Type-checking..."
          }
        ]
      }
    ]
  }
}
